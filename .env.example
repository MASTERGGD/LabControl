# Base de datos (SQLite para desarrollo, PostgreSQL para VPS)
DATABASE_URL=sqlite:///./data/labcontrol.db

# Seguridad JWT
SECRET_KEY=cambia-esta-clave-en-produccion-minimo-32-caracteres
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# App
APP_NAME=LabControl UTECAN
DEBUG=True

# Entorno: development | production
# En producción activa HSTS y upgrade-insecure-requests en CSP
APP_ENV=development

# Frontend URL (para CORS — cambiar a tu dominio en producción)
FRONTEND_URL=http://localhost:3000

# Telegram (opcional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

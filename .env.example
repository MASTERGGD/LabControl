# --- Base de datos -----------------------------------------------------------
#
# Desarrollo local con Docker Compose (usa el servicio 'db' interno):
#   DATABASE_URL=postgresql+psycopg2://labcontrol:labcontrol@db:5432/labcontrol
#
# Desarrollo local sin Docker (SQLite, cero configuracion):
#   DATABASE_URL=sqlite:///./data/labcontrol.db
#
# Produccion Railway / Render (pegar la URL que da la plataforma):
#   DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname
# Railway puede entregar postgresql://...; el backend lo normaliza.
#
DATABASE_URL=postgresql+psycopg2://labcontrol:labcontrol@db:5432/labcontrol

# Credenciales del contenedor PostgreSQL (docker-compose.prod.yml las lee)
DB_USER=labcontrol
DB_PASSWORD=labcontrol
DB_NAME=labcontrol

# --- Seguridad JWT -----------------------------------------------------------
SECRET_KEY=cambia-esta-clave-en-produccion-minimo-32-caracteres
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- Sesion web / inactividad -----------------------------------------------
# El token marca la expiracion maxima. El frontend cierra antes si no hay uso.
REACT_APP_IDLE_WARNING_MINUTES=40
REACT_APP_IDLE_TIMEOUT_MINUTES=45

# --- Proteccion de abuso / rate limit ---------------------------------------
# RATE_LIMIT_ENABLED=true activa limites en endpoints sensibles.
# Si usas Nginx/Proxy/CDN delante, habilita TRUST_PROXY_HEADERS para respetar
# X-Forwarded-For / X-Real-IP. Solo activarlo si el proxy es confiable.
RATE_LIMIT_ENABLED=true
TRUST_PROXY_HEADERS=false
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_QR_PER_MINUTE=30
RATE_LIMIT_SEARCH_PER_MINUTE=60
RATE_LIMIT_WRITE_PER_MINUTE=60
RATE_LIMIT_GENERAL_PER_MINUTE=300
LOGIN_MAX_FAILURES=5
LOGIN_LOCK_MINUTES=15

# --- App ---------------------------------------------------------------------
APP_NAME=S I G A - UTECAN
DEBUG=True

# Entorno: development | production
# En produccion activa HSTS y upgrade-insecure-requests en CSP
APP_ENV=development

# Frontend URL (para CORS -- cambiar a tu dominio en produccion)
FRONTEND_URL=http://localhost:3000

# Origenes permitidos para CORS, separados por coma.
# En produccion NO uses "*"; agrega solo tu dominio real.
CORS_ORIGINS=http://localhost:3000

# --- Frontend React -----------------------------------------------------------
# CRA lee estas variables al momento del build. En Railway, si cambias alguna,
# vuelve a desplegar/reconstruir el servicio frontend.
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000
REACT_APP_PUBLIC_APP_URL=http://localhost:3000

# --- Seed inicial -------------------------------------------------------------
# En produccion/demo con APP_ENV=production, SEED_ADMIN_PASSWORD es obligatorio.
# Esto evita imprimir contrasenas generadas en logs publicos de la plataforma.
SEED_ADMIN_EMAIL=admin@utecan.edu.mx
SEED_ADMIN_PASSWORD=

# --- Adjuntos de comunicados -------------------------------------------------
# Solo se aceptan PDF, JPG, PNG y WEBP. El backend valida MIME y firma del archivo.
COMUNICADOS_MAX_ADJUNTO_MB=5
COMUNICADOS_MAX_TOTAL_ADJUNTOS_MB=15
COMUNICADOS_MAX_ADJUNTOS=5
COMUNICADOS_ADJUNTOS_DIR=data/comunicados_adjuntos
COMUNICADOS_RESPALDOS_DIR=data/comunicados_respaldos

# --- Continuidad operativa --------------------------------------------------
# Los respaldos incluyen una exportacion consistente de la BD y archivos de data.
SYSTEM_DATA_DIR=data
SYSTEM_BACKUP_DIR=data/system_backups
SYSTEM_LOG_DIR=data/logs
SYSTEM_BACKUP_MIN_FREE_MB=500
SYSTEM_BACKUP_TIMEOUT_SECONDS=300

# --- Auditoria / bitacora ---------------------------------------------------
# La tabla audit_logs mantiene solo la ventana operativa. Lo anterior puede
# archivarse en JSONL comprimido desde /auditoria/retencion/archivar.
AUDIT_RETENTION_DAYS=365
AUDIT_ARCHIVE_ENABLED=true
AUDIT_ARCHIVE_DIR=data/audit_archives
AUDIT_ARCHIVE_BATCH_SIZE=5000

# --- SMTP (opcional) ---------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# --- Telegram (opcional) -----------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
